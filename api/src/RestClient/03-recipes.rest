### List recipes
GET {{baseUrl}}/api/recipes?page=1&limit=20
Accept: application/json

### Get recipe detail
GET {{baseUrl}}/api/recipes/{{recipeId}}
Accept: application/json

### Create a recipe from images
# Replace image paths and ensure familyMemberId is a real value.
# @name createRecipe
POST {{baseUrl}}/api/recipes
X-Family-Member-Id: {{familyMemberId}}
Content-Type: multipart/form-data; boundary=Boundary123

--Boundary123
Content-Disposition: form-data; name="rating"

2
--Boundary123
Content-Disposition: form-data; name="finishedDishImageIndex"

0
--Boundary123
Content-Disposition: form-data; name="files"; filename="recipe-photo-1.jpg"
Content-Type: image/jpeg

< {{image1}}
--Boundary123
Content-Disposition: form-data; name="files"; filename="recipe-photo-2.jpg"
Content-Type: image/jpeg

< {{image2}}
--Boundary123--

> {%
  if (response.body?.recipeId) {
    client.global.set("recipeId", response.body.recipeId);
  }
%}

### Update recipe notes and/or rating (PATCH — only included fields are applied)
PATCH {{baseUrl}}/api/recipes/{{recipeId}}
Content-Type: application/json

{
  "notes": "Reduce soy sauce by half next time.",
  "rating": 3
}

### Update only rating (omit notes to leave it unchanged)
PATCH {{baseUrl}}/api/recipes/{{recipeId}}
Content-Type: application/json

{
  "rating": 2
}

### Get original uploaded image  (all image routes are under /api/recipes/)
GET {{baseUrl}}/api/recipes/{{recipeId}}/original/0
Accept: image/*

### Get hero image (generated by import worker — returns 404 until import completes)
GET {{baseUrl}}/api/recipes/{{recipeId}}/hero
Accept: image/*

### Delete a recipe
DELETE {{baseUrl}}/api/recipes/{{recipeId}}
Accept: application/json

### Trigger recipe import
POST {{baseUrl}}/api/recipes/{{recipeId}}/import
Accept: application/json

