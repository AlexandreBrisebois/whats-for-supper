{
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/recipeapi-.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 7,
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
                }
            }
        ],
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithEnvironmentName"
        ]
    },
    "ConnectionStrings": {},
    "Cors": {
        "AllowedOrigins": [
            "http://localhost:3000",
            "http://localhost:3001"
        ]
    },
    "AllowedHosts": "*",
    "DataRoot": "/Users/alex/Code/whats-for-supper/data",
    "GEMINI_ENDPOINT": "https://generativelanguage.googleapis.com/v1beta/openai/",
    "GEMINI_MODEL_ID": "gemini-3-flash-preview",
    "GEMINI_CONTEXT_WINDOW": 1000000,
    "GEMINI_MAX_OUTPUT_TOKENS": 8192,
    "WorkflowThrottle": {
        "ExtractRecipe": 1,
        "GenerateHero": 1,
        "BackupDatabase": 1,
        "RestoreDatabase": 1,
        "DisasterRecovery": 1,
        "Default": 5
    },
    "WorkflowRetry": {
        "MaxRetries": 3
    }
}