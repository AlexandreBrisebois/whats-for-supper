# What's For Supper - Environment Variables Template
# Copy to .env.local and fill in your local values
# WARNING: Never commit .env.local to git!

# ============================================================================
# PHASE 0: CORE SERVICES
# ============================================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=recipes
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONNECTION_STRING=postgres://postgres:password@postgres:5432/recipes

# API (.NET)
API_HOST=0.0.0.0
API_PORT=5000
API_BASE_URL=http://localhost:5000
RECIPES_ROOT=/data/recipes

# PWA (Next.js)
PWA_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_LOCALE=en

# Docker Compose
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ============================================================================
# PHASE 1+: OPTIONAL SERVICES
# ============================================================================

# Redis (Phase 1+)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=redis://redis:6379

# Ollama (Phase 1+ - local LLM)
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral  # or gemma, neural-chat, etc.

# ============================================================================
# DEVELOPMENT & LOGGING
# ============================================================================

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5000

# Logging
LOG_LEVEL=Information
LOG_FORMAT=json  # json or text

# ============================================================================
# SECURITY (Leave blank in Phase 0, implement in Phase 2+)
# ============================================================================

# JWT Token Secret (Phase 2+)
JWT_SECRET=your-super-secret-key-change-in-production

# CORS Origins (Phase 1+)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# CALENDAR SYNC (Phase 4+)
# ============================================================================

# Google Calendar API (if implementing calendar sync)
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ============================================================================
# DEPLOYMENT (Usually in GitHub Secrets, not .env)
# ============================================================================

# Docker Registry (for push to ECR, Docker Hub, etc)
DOCKER_REGISTRY=
DOCKER_USERNAME=
DOCKER_PASSWORD=

# Production Postgres Connection
PROD_POSTGRES_CONNECTION_STRING=

# Production API URL
PROD_API_BASE_URL=https://api.example.com

# ============================================================================
# NOTES
# ============================================================================

# For local development (docker-compose):
#   POSTGRES_CONNECTION_STRING=postgres://postgres:password@postgres:5432/recipes
#   API_BASE_URL=http://api:5000
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
#
# For local dev servers (without docker):
#   POSTGRES_CONNECTION_STRING=postgres://postgres:password@localhost:5432/recipes
#   API_BASE_URL=http://localhost:5000
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
#
# For production (cloud):
#   POSTGRES_CONNECTION_STRING=postgres://user:pass@prod-db-host:5432/recipes
#   API_BASE_URL=https://api.example.com
#   NEXT_PUBLIC_API_BASE_URL=https://api.example.com
