# PWA Environment Variables (Next.js)

# API URL for client-side requests (usually /backend for Docker proxy)
NEXT_PUBLIC_API_BASE_URL=/backend

# API URL for server-side requests (SSR)
API_INTERNAL_URL=http://localhost:9001

# Environment name
NEXT_PUBLIC_ENVIRONMENT=development

# Hearth Secret: family passphrase used for stateless no-password auth (ADR 027)
# Set to a memorable passphrase shared with your household. Changing this invalidates all existing sessions.
HEARTH_SECRET=your family passphrase here
