{
  "name": "whats-for-supper-pwa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "mock-api": "prism mock ../specs/openapi.yaml -p 5001",
    "api:generate": "kiota generate -l typescript -c ApiClient -o ./src/lib/api/generated -d ../specs/openapi.yaml && node scripts/fix-kiota-imports.js",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npm run build && playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "agent:slice": "python3 ../scripts/agent/slice.py",
    "agent:drift": "python3 ../scripts/agent/drift.py",
    "agent:audit": "python3 ../scripts/agent/test_ops.py --audit",
    "agent:test:impact": "python3 ../scripts/agent/test_ops.py --impact"
  },
  "dependencies": {
    "@microsoft/kiota-abstractions": "^1.0.0-preview.100",
    "@microsoft/kiota-http-fetchlibrary": "^1.0.0-preview.100",
    "@microsoft/kiota-serialization-form": "^1.0.0-preview.100",
    "@microsoft/kiota-serialization-json": "^1.0.0-preview.100",
    "@microsoft/kiota-serialization-multipart": "^1.0.0-preview.100",
    "@microsoft/kiota-serialization-text": "^1.0.0-preview.100",
    "@stoplight/prism-cli": "^5.15.10",
    "@swc/helpers": "^0.5.21",
    "axios": "^1.15.2",
    "canvas-confetti": "^1.9.3",
    "framer-motion": "^12.4.7",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.4",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
