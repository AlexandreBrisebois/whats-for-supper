# What's For Supper - Environment Variables Template
# Copy to .env.local and fill in your local values
# WARNING: Never commit .env.local to git!

# ============================================================================
# CORE SERVICES
# ============================================================================

# PostgreSQL (Matches infrastructure.yml defaults)
POSTGRES_USER=recipe_app
POSTGRES_PASSWORD=secure_dev_password
POSTGRES_DB=recipe_app_db
POSTGRES_PORT=5432
POSTGRES_CONNECTION_STRING=postgres://recipe_app:secure_dev_password@postgres:5432/recipe_app_db

# API (.NET)
API_PORT=5000
API_BASE_URL=http://api.wfs.localhost
RECIPES_ROOT=/data/recipes

# PWA (Next.js)
PWA_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://api.wfs.localhost
NEXT_PUBLIC_LOCALE=en

# ============================================================================
# AI & EXTRACTION
# ============================================================================

# Agent Framework (Ollama / Gemini)
# OLLAMA_API_ENDPOINT should point to the Ollama API (v1)
OLLAMA_API_ENDPOINT=http://host.docker.internal:11434/v1
OLLAMA_MODEL_ID=gemma4:e4b
GEMINI_API_KEY=

# ============================================================================
# DEVELOPMENT & LOGGING
# ============================================================================

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# Logging
LOG_LEVEL=Information
LOG_FORMAT=json

# ============================================================================
# SECURITY (Phase 2+)
# ============================================================================

# JWT Token Secret
JWT_SECRET=your-super-secret-key-change-in-production

# CORS Origins
CORS_ALLOWED_ORIGINS=http://pwa.wfs.localhost,http://localhost:3000,http://localhost:3001

# ============================================================================
# CALENDAR SYNC (Phase 4+)
# ============================================================================

# Google Calendar API
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ============================================================================
# NOTES & QUICK START
# ============================================================================

# For standard Docker development (task up):
#   POSTGRES_CONNECTION_STRING=postgres://recipe_app:secure_dev_password@postgres:5432/recipe_app_db
#   NEXT_PUBLIC_API_BASE_URL=http://api.wfs.localhost
#
# For running the API/PWA locally outside Docker:
#   POSTGRES_CONNECTION_STRING=postgres://recipe_app:secure_dev_password@localhost:5432/recipe_app_db
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
#
# Task runner variables:
#   WFS_REGISTRY: The registry to push/pull images from (e.g., 192.168.1.226:5050)
#   TARGET_DB_HOST: The database host for backup/restore (e.g., localhost or NAS IP)
