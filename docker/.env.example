# What's For Supper - Environment Variables Template
# Copy to .env.local and fill in your local values
# WARNING: Never commit .env.local to git!

# ============================================================================
# CORE SERVICES & INFRASTRUCTURE
# ============================================================================

# Docker Engine Endpoint (Linux/macOS default)
# DOCKER_ENDPOINT=unix:///var/run/docker.sock

# Traefik (Edge Proxy)
TRAEFIK_HTTP_PORT=80
TRAEFIK_ADMIN_PORT=8080

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=
DOMAIN_NAME=your.domaine

# PostgreSQL
POSTGRES_USER=recipe_app
POSTGRES_PASSWORD=secure_dev_password
POSTGRES_DB=recipe_app_db
POSTGRES_PORT=5432
# Connection string used by the API container (Internal network)
POSTGRES_CONNECTION_STRING=postgres://recipe_app:secure_dev_password@postgres:5432/recipe_app_db

# ============================================================================
# API (.NET)
# ============================================================================

# External Hostname (Traefik)
# Local: api.wfs.localhost | Cloudflare: api.wfs.${DOMAIN_NAME}
API_HOST=api.wfs.localhost
# Port for direct access (optional in dev)
API_PORT=9001
ASPNETCORE_ENVIRONMENT=Development
# Internal URL used by the PWA to reach the API (service name in Docker)
API_INTERNAL_URL=http://api:9001

# ============================================================================
# PWA (Next.js)
# ============================================================================

# External Hostname (Traefik)
# Local: pwa.wfs.localhost | Cloudflare: wfs.${DOMAIN_NAME}
PWA_HOST=pwa.wfs.localhost
# Port for direct access (optional in dev)
PWA_PORT=3000
# /backend routes through the Next.js rewrite proxy -> api container.
NEXT_PUBLIC_API_BASE_URL=/backend
NEXT_PUBLIC_ENVIRONMENT=development
# Hearth Secret: family passphrase used for stateless no-password auth (ADR 027)
# Set to a memorable passphrase shared with your household. Changing this invalidates all existing sessions.
HEARTH_SECRET=your family passphrase here

# ============================================================================
# AI & EXTRACTION (Google Gemini)
# ============================================================================

GEMINI_API_KEY=
# Use models/gemini-3-flash for extraction
GEMINI_MODEL_ID=models/gemini-3-flash
# Optional: Project ID for GCP-based Vertex AI (if applicable)
GEMINI_PROJECT_ID=
# OpenAI-compatible endpoint (defaults to Google's v1beta)
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/

# ============================================================================
# STORAGE & DATA
# ============================================================================

# Recipes Storage (Map to local project root folder)
# Set to a local path (e.g., ../../data) for bind mounting.
DATA_ROOT=../../data

# ============================================================================
# SECURITY & CORS
# ============================================================================

# CORS Origins (Comma separated)
CORS_ALLOWED_ORIGINS=http://pwa.wfs.localhost,http://localhost:3000

# JWT Token Secret (Phase 2+)
JWT_SECRET=your-super-secret-key-change-in-production

# Hearth Secret (Shared family passphrase for no-password onboarding)
HEARTH_SECRET=change-this-to-a-strong-secret

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=Information
LOG_FORMAT=json
